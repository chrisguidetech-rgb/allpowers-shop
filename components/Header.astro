---
import PromoStrip from './PromoStrip.astro';
---
<header class="sticky top-0 z-50 w-full bg-white/90 backdrop-blur border-b border-gray-100">
  <PromoStrip />
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-2xl font-black tracking-tighter text-gray-900">
      PWR<span class="text-brand">STATION</span>
    </a>
    <nav class="hidden md:flex gap-6 font-medium text-gray-600">
      <a href="#products" class="hover:text-brand transition-colors">Products</a>
      <a href="#compare" class="hover:text-brand transition-colors">Compare</a>
      <a href="#faq" class="hover:text-brand transition-colors">FAQ</a>
    </nav>
    <a href="https://iallpowers.eu/?ref=Allpowers-compact-energy&utm_source=aff" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex bg-brand hover:bg-brand-dark text-white px-5 py-2 rounded-full font-bold transition-all transform hover:scale-105">
      Shop Allpowers
    </a>
  </div>
</header>
