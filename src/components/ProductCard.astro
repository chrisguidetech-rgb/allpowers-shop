---
const { product } = Astro.props;
const { data } = product;
---
<div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full relative group">
  {data.featured && (
    <div class="absolute top-4 left-4 bg-yellow-400 text-yellow-900 text-xs font-bold px-3 py-1 rounded-md z-10 shadow-sm">
      Most Popular
    </div>
  )}
  <div class="aspect-square bg-white rounded-xl mb-6 overflow-hidden flex items-center justify-center p-2">
    <img src={data.image} alt={data.name} class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500" />
  </div>
  <h3 class="text-xl font-bold text-gray-900 mb-2 leading-tight">{data.name}</h3>
  <p class="text-sm text-gray-500 mb-4 flex-grow">{data.shortDescription}</p>
  
  <div class="space-y-2 mb-6">
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Capacity:</span>
      <span class="font-semibold text-gray-900">{data.batteryCapacity}</span>
    </div>
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Output:</span>
      <span class="font-semibold text-gray-900">{data.outputWatts}</span>
    </div>
  </div>

  <div class="mt-auto">
    <div class="flex items-center justify-between mb-4">
      <div class="flex flex-col">
        <span class="text-xs text-gray-400 font-medium">Starting from</span>
        <span class="text-2xl font-black text-gray-900">{data.price}</span>
      </div>
      {data.couponCode && (
        <div class="text-right">
          <span class="block text-xs font-medium text-gray-500">Extra 10% Code:</span>
          <span class="bg-red-50 text-brand border border-red-100 px-2 py-1 rounded text-sm font-bold">{data.couponCode}</span>
        </div>
      )}
    </div>
    <a href={data.affiliateUrl} target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-gray-900 hover:bg-brand text-white font-bold py-3.5 rounded-xl transition-colors">
      Claim Deal
    </a>
  </div>
</div>
